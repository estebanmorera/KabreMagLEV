Header
  CHECK KEYWORDS Warn
  Mesh DB "." "mesh"
  Include Path ""
  Results Directory "results"
End

! CircuitBuilder / CoilSolver definitions
Include "HMB_circuit.definition"

Simulation
  Max Output Level = 7
  Coordinate System = Cartesian
  Coordinate Mapping(3) = 1 2 3

  Simulation Type = Transient
  TimeStepping Method = BDF
  BDF Order = 1
  Timestep Sizes(1) = 1.0e-3
  Timestep Intervals(1) = 1
  Output Intervals(1) = 1


End

Constants
  Permittivity of Vacuum = 8.85418781e-12
  Permeability of Vacuum  = 1.25663706e-6
End

! -------------------------
! BODY FORCES
!   BF1 viene de HMB_circuit.definition (I1_Source)
! -------------------------
Body Force 2
  Name = "M_plus"
  Magnetization 1 = 0
  Magnetization 2 = 0
  Magnetization 3 = Real 8.0e5
End

Body Force 3
  Name = "M_minus"
  Magnetization 1 = 0
  Magnetization 2 = 0
  Magnetization 3 = Real -8.0e5
End

! ----------
! MATERIALES
! ----------
Material 1
  Name = "Air"
  Relative Permeability = 1.00000037
  Relative Permittivity = 1.00059
  Density = 1.205
End

Material 2
  Name = "Mag +"
  Relative Permeability = 1.05
End

Material 3
  Name = "Mag -"
  Relative Permeability = 1.05
End

Material 4
  Name = "Copper"
  Relative Permeability = 1.0
  Electric Conductivity = 5.8e7
End

! ----------------
! ECUACIONES
!   Eq 1 = bobina (circuit + coil + campo)
!   Eq 2 = resto (solo campo)
! ----------------
Equation 1
  Name = "CoilEquation"
  Active Solvers(5) = 1 2 3 4 5 
End

Equation 2
  Name = "MagneticsOnly"
  Active Solvers(3) = 3 4 5 
End

! =========================
! SOLVERS
! =========================

! ---------- Solver 1: Circuit equations ----------
Solver 1
  Exec Solver = Always
  Equation = "Circuits"
  Variable = "X"
  No Matrix = Logical True
  Procedure = "CircuitsAndDynamics" "CircuitsAndDynamics"
End

! ---------- Solver 2: CoilSolver (acopla el circuito al dominio electromagnético) ----------
Solver 2
  Exec Solver = Before all
  Equation = "CoilSolver"
  Procedure = "CoilSolver" "CoilSolver"
  Variable = "W"
  Steady State Convergence Tolerance = 1.0e-6

  Linear System Solver = Iterative
  Linear System Preconditioning = ILU1
  Linear System Iterative Method = GCR
  Linear System Max Iterations = 10000
  Linear System Convergence Tolerance = 1.0e-6

  Normalize Coil Current = Logical True
  Fix Input Current Density = Logical True
  Coil Closed = Logical True
  Narrow Interface = Logical True
  Save Coil Set = Logical True
  Save Coil Index = Logical True
  Single Coil Cut = Logical True
End

! ---------- Solver 3: Campo magnético (WhitneyAV) — ITERATIVE robusto ----------
Solver 3
  Exec Solver = Always
  Equation = "MGDynamics"
  Procedure = "MagnetoDynamics" "WhitneyAVSolver"

  Variable = "AV"
  Export Lagrange Multiplier = Logical True

  Stabilize = True
  Optimize Bandwidth = True
  Use Tree Gauge = Logical False
  Use Piola Transform = Logical True

  Linear System Solver = Iterative
  Linear System Scaling = True
  Linear System Iterative Method = GCR
  Linear System Preconditioning = ILU0
  Linear System GCR Restart = 100
  Linear System Max Iterations = 5000
  Linear System Convergence Tolerance = 1.0e-8
  Linear System Abort Not Converged = Logical True
  Linear System Residual Output = 30
End




! ---------- Solver 4: Postpro - B, H, J (campos) — ITERATIVE ----------
Solver 4
  Exec Solver = After Simulation
  Equation = "MGDynPost"
  Procedure = "MagnetoDynamics" "MagnetoDynamicsCalcFields"

  Linear System Solver = Iterative
  Linear System Iterative Method = BiCGStab
  Linear System Preconditioning = ILU0

  Linear System Max Iterations = 1000
  Linear System Convergence Tolerance = 1.0e-10

  Linear System Abort Not Converged = True

  Potential Variable = "AV"

  Calculate Magnetic Flux Density   = Logical True
  Calculate Magnetic Field Strength = Logical False
  Calculate Current Density         = Logical False
  Calculate Elemental Fields        = Logical False
  Calculate Nodal Fields            = Logical False

  Calculate Maxwell Stress = Logical False

  Average Within Materials = Logical False

End


! ---------- Solver 5: Guardar resultados (VTU) ----------
Solver 5
  Exec Solver = Never
End




! -------------------------
! CUERPOS (mismo mallado: 4 imanes + bobina + aire)
! -------------------------
Body 1
  Target Bodies(1) = 1      ! exterior inferior
  Name = "OuterMag1"
  Equation = 2
  Material = 3
  Body Force = 3            ! +z
End

Body 2
  Target Bodies(1) = 3      ! exterior superior
  Name = "OuterMag2"
  Equation = 2
  Material = 2
  Body Force = 3            ! +z
End

Body 3
  Target Bodies(1) = 5      ! interior inferior
  Name = "InnerMag1"
  Equation = 2
  Material = 2
  Body Force = 2            ! -z
End

Body 4
  Target Bodies(1) = 7      ! interior superior
  Name = "InnerMag2"
  Equation = 2
  Material = 3
  Body Force = 2            ! -z
End

Body 5
  Target Bodies(1) = 20      ! bobina
  Name = "Coil"
  Equation = 1
  Material = 4
  Body Force = 1            ! viene del HMB_circuit.definition (I1_Source)
End

Body 6
  Target Bodies(1) = 30      ! aire
  Name = "Air"
  Equation = 2
  Material = 1
End

! -------------------------
! BC EXTERNA (aire infinito)
! -------------------------
Boundary Condition 1
  Name = "ExternalBC"
  Target Boundaries(3) = 28 29 30

  AV {e} 1 = Real 0
  AV {e} 2 = Real 0
  AV {e} 3 = Real 0
End

